# Required: your Anthropic API key.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default Claude model.
# Examples: claude-opus-4-5, claude-sonnet-4-5, claude-haiku-4-5
SHREK_MODEL=claude-sonnet-4-5

# Optional: max tokens per response (default 8192)
SHREK_MAX_TOKENS=8192

# Optional: workspace root the agent is allowed to touch (default: cwd)
SHREK_WORKSPACE=.

# Optional: extra allowed shell commands prefixes, comma-separated
# (defaults to a safe allow-list; set to "*" to allow anything — dangerous)
SHREK_BASH_ALLOWLIST=
